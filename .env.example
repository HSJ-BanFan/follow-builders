# Follow Builders Daily Digest 配置
# 复制此文件为 .env 并填入你的真实值

# Notion Integration Token (必需)
# 从 https://www.notion.so/my-integrations 获取
NOTION_API_KEY=secret_xxx

# Notion 数据库 ID (必需)
# 从数据库 URL 中获取: https://www.notion.so/workspace/xxx?v=...
# xxx 部分就是 DATABASE_ID
NOTION_DATABASE_ID=your-database-id-here

# 语言设置 (可选)
# zh = 中文, en = 英文, bilingual = 双语
FB_LANGUAGE=zh

# 时区 (可选)
FB_TIMEZONE=Asia/Shanghai

# 内容限制 (可选)
FB_MAX_TWEETS=2
FB_MAX_PODCASTS=2
FB_MAX_BLOGS=2
